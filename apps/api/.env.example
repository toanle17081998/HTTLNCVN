NODE_ENV=development
PORT=3001
APP_NAME=htnc-api

# Database (Prisma reads DATABASE_URL directly)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/htnc

# Redis (used by infra, reserved for future queue/cache features)
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Homepage cache TTL (seconds)
HOMEPAGE_CACHE_TTL_SECONDS=300
